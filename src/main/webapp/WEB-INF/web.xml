<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <servlet>
        <servlet-name>ListProductsServlet</servlet-name>
        <servlet-class>com.hotguy.warehouse13.view.ListProductsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ListProductsServlet</servlet-name>
        <url-pattern>/listar</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>FindProductsServlet</servlet-name>
        <servlet-class>com.hotguy.warehouse13.view.FindProductsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FindProductsServlet</servlet-name>
        <url-pattern>/buscar</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>InsertProductServlet</servlet-name>
        <servlet-class>com.hotguy.warehouse13.view.InsertProductServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>InsertProductServlet</servlet-name>
        <url-pattern>/insertar</url-pattern>
    </servlet-mapping>

</web-app>
